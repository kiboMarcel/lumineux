{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "Default": ""
  },
  "Jwt": {
    "Issuer": "Lumineux",
    "Audience": "Lumineux",
    "SigningKey": "",
    "ExpirationMinutes": 60
  },
  "AutoClose": {
    "Enabled": true,
    "PollingIntervalSeconds": 300,
    "MaxOpenHours": 6,
    "DefaultDurationHours": 3
  },
  "AllowedHosts": "*"
}
