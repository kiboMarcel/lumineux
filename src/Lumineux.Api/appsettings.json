{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "Default": ""
  },
  "Jwt": {
    "Issuer": "Lumineux",
    "Audience": "Lumineux",
    "SigningKey": ""
  },
  "AutoClose": {
    "Enabled": true,
    "PollingIntervalSeconds": 300,
    "MaxOpenHours": 3,
    "DefaultDurationHours": 3
  },
  "Email": {
    "Provider": "Logging",
    "FromAddress": "no-reply@lumineux.example",
    "Smtp": {
      "Host": "",
      "Port": 587,
      "UseStartTls": true,
      "User": "",
      "Password": ""
    }
  },
  "MemberReference": {
    "Format": "LUM-{yyyy}-{seq:00000}"
  },
  "Auth": {
    "AccessTokenMinutes": 60,
    "MaxFailedAttempts": 5,
    "LockoutMinutes": 15,
    "PasswordMinLength": 8,
    "PasswordResetMinutes": 30,
    "PasswordResetUrlBase": "https://localhost:4200/auth/reset-password",
    "Bootstrap": {
      "MemberReference": "",
      "Permissions": []
    }
  },
  "Cors": {
    "//": "Origines autorisées pour la SPA. Vide par défaut : renseigner explicitement l'origine de production.",
    "AllowedOrigins": []
  },
  "AllowedHosts": "*"
}
